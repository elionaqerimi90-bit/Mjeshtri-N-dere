// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  MJESHTER
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  name             String
  phone            String?
  role             Role
  mjeshtriProfile  MjeshtriProfile?
  clientBookings   Booking[]         @relation("ClientBookings")
  mjeshtriBookings Booking[]         @relation("MjeshtriBookings")
  createdAt        DateTime          @default(now())
}

enum Category {
  ELEKTRICIST
  HIDRAULIK
  FRIZER
  BOJAXHI
  ZDRUKTHETAR
  MEKANIK
  PASTRIM
  KOPSHTAR
  KLIMATIZIM
  NDERTIMTAR
  KUZHINIER
  FOTOGRAF
  CELESA
  TRANSPORT
  IT
  MOBILERI
  BABYSITTING
  TUTOR
}

model MjeshtriProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  category    Category
  basePrice   Float
  description String?
  radiusKm    Int      @default(15)
  avatarUrl   String?
  rating      Float    @default(0)
  totalJobs   Int      @default(0)
  createdAt   DateTime @default(now())
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model Booking {
  id          String        @id @default(uuid())
  clientId    String
  client      User          @relation("ClientBookings", fields: [clientId], references: [id])
  mjeshtriId  String
  mjeshtri    User          @relation("MjeshtriBookings", fields: [mjeshtriId], references: [id])
  scheduledAt DateTime
  status      BookingStatus @default(PENDING)
  price       Float?
  distanceKm  Float?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}